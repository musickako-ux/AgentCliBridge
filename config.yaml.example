# Leave endpoints empty to use claude CLI's own authentication
# 留空则直接使用 claude CLI 自身的认证配置
endpoints: []
#  - name: "claude-main"
#    provider: "claude"
#    model: "claude-sonnet-4-20250514"
#  - name: "codex"
#    provider: "codex"
#    model: "o3-mini"
#  - name: "gemini"
#    provider: "gemini"
#    model: "gemini-2.5-pro"

locale: en  # "zh" for Chinese
log_level: info  # debug | info | warn | error

# Structured log configuration (overrides log_level when log.level is set)
log:
  level: info           # debug | info | warn | error
  file:
    enabled: false
    dir: "./logs"        # Log file directory
    max_size_mb: 10      # Max size per file before rotation
    max_files: 5         # Number of rotated files to keep

agent:
  allowed_tools:
    - Read
    - Edit
    - Bash
    - Grep
    - Glob
    - WebSearch
    - WebFetch
  permission_mode: "acceptEdits"
  max_turns: 50
  max_budget_usd: 2.0
  max_parallel: 1  # Number of concurrent auto-task executions (1 = sequential)
  system_prompt: ""
  cwd: ""
  timeout_seconds: 300
  memory:
    enabled: true
    auto_summary: true
    max_memories: 50
  skill:
    enabled: true
  session:
    enabled: true             # Enable multi-session (concurrent conversations per user)
    max_per_user: 3           # Max concurrent sub-sessions per user
    idle_timeout_minutes: 30  # Auto-close idle sub-sessions after this time
    dispatcher_budget: 0.05   # Max budget for dispatcher classifier
    classifier_model: ""      # Model for classifier (empty = use default)

workspace:
  base_dir: "./workspaces"
  isolation: true

access:
  allowed_users: []
  allowed_groups: []

redis:
  enabled: false
  url: ""

platforms:
  telegram:
    enabled: true
    token: "your-telegram-bot-token"
    chunk_size: 4000
  discord:
    enabled: false
    token: ""
    chunk_size: 1900

# Webhook server for external triggers (GitHub, API, etc.)
webhook:
  enabled: false
  port: 3100
  token: "your-secret-token"  # Bearer token for /api/task
  github_secret: ""            # HMAC secret for GitHub webhooks

# Cron-like scheduled auto-tasks
# cron:
#   - schedule_minutes: 60
#     user_id: "123456"
#     platform: "telegram"
#     chat_id: "123456"
#     description: "Generate daily status report"
cron: []
