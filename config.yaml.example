# Leave endpoints empty to use claude CLI's own authentication
# 留空则直接使用 claude CLI 自身的认证配置
endpoints: []
#  - name: "default"
#    base_url: ""
#    api_key: "sk-your-api-key"
#    model: "claude-sonnet-4-20250514"

locale: en  # "zh" for Chinese

agent:
  allowed_tools:
    - Read
    - Edit
    - Bash
    - Grep
    - Glob
    - WebSearch
    - WebFetch
  permission_mode: "acceptEdits"
  max_turns: 50
  max_budget_usd: 2.0
  system_prompt: ""
  cwd: ""
  timeout_seconds: 300
  memory:
    enabled: true
    auto_summary: true
    max_memories: 50
  skill:
    enabled: true

workspace:
  base_dir: "./workspaces"
  isolation: true

access:
  allowed_users: []
  allowed_groups: []

redis:
  enabled: false
  url: ""

platforms:
  telegram:
    enabled: true
    token: "your-telegram-bot-token"
    chunk_size: 4000
  discord:
    enabled: false
    token: ""
    chunk_size: 1900
