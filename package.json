{
  "name": "@emqo/claudebridge",
  "version": "0.6.0",
  "description": "Bridge claude CLI to chat platforms (Telegram, Discord) with scheduled auto-tasks, autonomous project management, HITL approval, conditional branching, webhook triggers, parallel execution, and observability",
  "main": "dist/index.js",
  "bin": {
    "claudebridge": "dist/cli.js",
    "claudebridge-ctl": "dist/ctl.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "discord",
    "bridge",
    "agent",
    "chatbot",
    "hitl",
    "webhook",
    "multi-agent"
  ],
  "files": [
    "dist",
    "config.yaml.example"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emqo/ClaudeBridge.git"
  },
  "homepage": "https://github.com/Emqo/ClaudeBridge#readme",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "undici": ">=6.23.0"
  }
}
