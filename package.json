{
  "name": "@emqo/agent-cli-bridge",
  "version": "0.12.1",
  "description": "Bridges CLI-based AI agents (Claude, Codex, Gemini) to chat platforms (Telegram, Discord) with scheduled auto-tasks, autonomous project management, HITL approval, conditional branching, webhook triggers, parallel execution, and observability",
  "main": "dist/index.js",
  "bin": {
    "agent-cli-bridge": "dist/cli.js",
    "agent-cli-bridge-ctl": "dist/ctl.js",
    "acb": "dist/cli.js",
    "acb-ctl": "dist/ctl.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "discord",
    "bridge",
    "agent",
    "chatbot",
    "hitl",
    "webhook",
    "multi-agent"
  ],
  "files": [
    "dist",
    "config.yaml.example"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emqo/AgentCliBridge.git"
  },
  "homepage": "https://github.com/Emqo/AgentCliBridge#readme",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cross-spawn": "^7.0.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.9.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "undici": ">=6.23.0"
  }
}
